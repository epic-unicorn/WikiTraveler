# ── WikiTraveler Node — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Vercel Postgres, Neon, Supabase, or self-hosted)
DATABASE_URL=postgresql://wikitraveler:wikitraveler@localhost:5432/wikitraveler

# ── Node Identity ─────────────────────────────────────────────────────────────
# A stable, unique ID for this node. Used in gossip deltas and peer discovery.
NODE_ID=my-node-1

# The public URL of this node (used when registering with peers and in gossip).
NODE_URL=http://localhost:3000

# Geographic region or city name (displayed on the dashboard).
NODE_REGION=Eindhoven, Netherlands

# ── Authentication ────────────────────────────────────────────────────────────
# RS256 key pair for signing JWTs. Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then set these to the PEM content (replace newlines with \n).
NODE_PRIVATE_KEY=
NODE_PUBLIC_KEY=

# Allow public user registration on this node (true/false).
OPEN_REGISTRATION=true

# First admin account — created automatically on startup if set.
# Comment out after the account is created to avoid re-seeding on every restart.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Optional: legacy HS256 fallback secret (used only when NODE_PRIVATE_KEY is unset).
# JWT_SECRET=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origins for the API. Use "*" to allow all, or a comma-separated list.
CORS_ORIGINS=*

# ── Gossip Protocol ───────────────────────────────────────────────────────────
# How often the gossip cron runs (in hours). Default: 24.
# Set to a small fraction (e.g. 0.003 ≈ 10s) for local demos.
GOSSIP_INTERVAL_HOURS=24

# Secret passed as Authorization: Bearer <value> to protect the cron endpoint.
# Required on Vercel (set in vercel.json referencing @cron-secret).
CRON_SECRET=


# ── Registry ─────────────────────────────────────────────────────────────────
# URL of the central registry. Nodes register on startup and query for peers
# during each gossip cron run. Required in production; omit for isolated dev.
# REGISTRY_URL=https://registry.wikitraveler.org

# ── AI Agent (GPT-4o Vision + Gap-Fill) ──────────────────────────────────────
# Required to enable AI_GUESS tier features:
#   - Vision analysis when photos are uploaded via the Field Kit
#   - On-demand analysis via POST /api/properties/:id/analyze
#   - Batch gap-fill via GET /api/cron/ai-scan
# Leave blank to disable AI features — the node runs fine without it.
OPENAI_API_KEY=

# ── OSM / Overpass Ingestion ─────────────────────────────────────────────────
# Bounding box for the Overpass API query: "lat_min,lon_min,lat_max,lon_max"
# Default: Eindhoven, Netherlands
OSM_BBOX=51.39,5.42,51.49,5.52

# Optional: absolute path to a cached Overpass fixture JSON file.
# When set and the file exists, the Overpass API is not called.
# The fixture is created automatically on first `pnpm osm:ingest` run.
# OSM_FIXTURE_PATH=/abs/path/to/scripts/fixtures/eindhoven-osm.json


# ── Field Kit (apps/field-kit) ────────────────────────────────────────────────
# Points the Field Kit mobile app to a node. Only needed when running field-kit separately.
NEXT_PUBLIC_NODE_API_URL=http://localhost:3000

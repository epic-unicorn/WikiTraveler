{
  "manifest_version": 3,
  "name": "WikiTraveler Lens",
  "version": "0.1.0",
  "description": "Overlay community-verified accessibility data on booking websites.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://www.booking.com/*",
    "*://*.expedia.com/*",
    "*://*.hotels.com/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.booking.com/*",
        "*://*.expedia.com/*",
        "*://*.hotels.com/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

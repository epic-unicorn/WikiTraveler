{
  "version": 2,
  "builds": [
    {
      "src": "apps/node/next.config.js",
      "use": "@vercel/next"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/gossip",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/ai-scan",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/wheelmap-sync",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/osm-ingest",
      "schedule": "0 4 * * 1"
    }
  ],
  "env": {
    "NODE_ID": "@node-id",
    "NODE_URL": "@node-url",
    "NODE_PRIVATE_KEY": "@node-private-key",
    "NODE_PUBLIC_KEY": "@node-public-key",
    "DATABASE_URL": "@database-url",
    "CORS_ORIGINS": "*",
    "CRON_SECRET": "@cron-secret",
    "OPENAI_API_KEY": "@openai-api-key",
    "WHEELMAP_API_KEY": "@wheelmap-api-key",
    "BOOTSTRAP_PEERS": "@bootstrap-peers"
  }
}

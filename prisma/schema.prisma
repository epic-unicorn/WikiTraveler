// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Reliability tier enum — mirrors the core package
// ---------------------------------------------------------------------------
enum Tier {
  OFFICIAL
  AI_GUESS
  VERIFIED
  CONFIRMED
}

// ---------------------------------------------------------------------------
// Source type — which external system or pipeline originated the fact
// ---------------------------------------------------------------------------
enum SourceType {
  WIKIDATA
  WHEELMAP
  WHEEL_THE_WORLD
  AUDITOR
}

// ---------------------------------------------------------------------------
// Travel property (keyed by Wikidata Q-identifier)
// ---------------------------------------------------------------------------
model Property {
  id          String   @id @default(cuid())
  canonicalId String   @unique
  name        String
  location   String
  osmId      String?  @unique
  wheelmapId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  facts      AccessibilityFact[]
  audits     AuditSubmission[]
}

// ---------------------------------------------------------------------------
// A single accessibility fact for a property
// ---------------------------------------------------------------------------
model AccessibilityFact {
  id            String     @id @default(cuid())
  propertyId    String
  property      Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  fieldName     String
  value         String
  tier          Tier       @default(OFFICIAL)
  sourceType    SourceType @default(AUDITOR)
  sourceNodeId  String
  submittedBy   String?
  signatureHash String?
  timestamp     DateTime   @default(now())

  @@unique([propertyId, fieldName, sourceNodeId])
  @@index([propertyId])
  @@index([tier])
}

// ---------------------------------------------------------------------------
// Raw community audit submission (kept for audit trail)
// ---------------------------------------------------------------------------
model AuditSubmission {
  id           String   @id @default(cuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  auditorToken String?
  // JSON array of { fieldName, value } objects
  facts        Json
  // JSON array of base64-encoded images (MVP: stored in DB)
  photoUrls    Json     @default("[]")
  createdAt    DateTime @default(now())

  @@index([propertyId])
}

// ---------------------------------------------------------------------------
// Peer node registry
// ---------------------------------------------------------------------------
model NodePeer {
  id        String   @id @default(cuid())
  url       String   @unique
  publicKey String?  // RSA public key PEM — cached from peer's /api/nodeinfo
  lastSeen  DateTime @default(now())
  isActive  Boolean  @default(true)
}

// ---------------------------------------------------------------------------
// Gossip sync history
// ---------------------------------------------------------------------------
model GossipSnapshot {
  id           String   @id @default(cuid())
  fromNodeId   String
  snapshotHash String
  appliedAt    DateTime @default(now())
  factCount    Int      @default(0)
}
